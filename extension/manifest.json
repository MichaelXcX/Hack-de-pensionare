{
  "manifest_version": 3,
  "name": "The Anarchist",
  "version": "1.0.0",
  "description": "A chaotic multi-functional Chrome extension",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "notifications",
    "scripting",
    "alarms",
    "tts",
    "windows",
    "tabs",
    "webNavigation"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/pngwing.com.png",
      "48": "icons/pngwing.com.png",
      "128": "icons/pngwing.com.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["stutter.js", "tts.js", "content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://api.flowery.pw/*",
    "*://*.leetcode.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/grass.jpeg", "assets/alex_sprite.png", "assets/stick-push.svg", "assets/lighter.png", "assets/fire.png", "offscreen.html", "offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
