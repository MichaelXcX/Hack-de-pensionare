{
  "manifest_version": 3,
  "name": "The Anarchist",
  "version": "1.0.0",
  "description": "A chaotic multi-functional Chrome extension",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "notifications",
    "tts",
    "windows"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["stutter.js", "tts.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://api.flowery.pw/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/grass.jpeg"],
      "matches": ["<all_urls>"]
    }
  ]
}
